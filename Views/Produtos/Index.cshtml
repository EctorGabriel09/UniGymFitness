@model IEnumerable<UniGymFitness.Models.Produto>
@using System.Globalization

@{
    ViewData["Title"] = "Produtos";
    Layout = "~/Views/Shared/_DashboardLayout.cshtml";
}

<div class="container">

    <div class="d-flex justify-content-between align-items-center mb-4">
        <div>
            <h2 class="fw-bold">Produtos</h2>
            <p class="text-muted">Gerencie os produtos e serviços da Uni Gym Fitness.</p>
        </div>

        <a asp-controller="Produtos" asp-action="Criar" class="btn btn-warning fw-bold">
            + Novo Produto
        </a>
    </div>

    <table class="table table-hover table-bordered align-middle">
        <thead class="table-dark">
            <tr>
                <th>Nome</th>
                <th>Preço</th>
                <th>Estoque</th>
                <th>Descrição</th>
                <th width="200">Ações</th>
            </tr>
        </thead>

        <tbody>
        @foreach (var produto in Model)
        {
            <tr>
                <td>@produto.Nome</td>

                <td>
                    @produto.Preco.ToString("C", new CultureInfo("pt-BR"))
                </td>

                <td>@produto.Estoque</td>
                <td>@produto.Descricao</td>

                <td>
                    <a asp-controller="Produtos"
                       asp-action="Editar"
                       asp-route-id="@produto.Id"
                       class="btn btn-primary btn-sm">
                        Editar
                    </a>

                    <form asp-controller="Produtos"
                          asp-action="Excluir"
                          asp-route-id="@produto.Id"
                          method="post"
                          class="d-inline"
                          onsubmit="return confirm('Tem certeza que deseja excluir este produto?');">
                        <button type="submit" class="btn btn-danger btn-sm">
                            Excluir
                        </button>
                    </form>
                </td>
            </tr>
        }
        </tbody>
    </table>

</div>
