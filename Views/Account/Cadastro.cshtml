@model UniGymFitness.Models.Usuario

@{
    ViewData["Title"] = "Cadastro";
}

<section class="login-section">
    <div class="login-card cadastro-card">

        <div class="text-center mb-4">
            <img src="~/images/logo/logo-branca.png"
                 alt="Uni Gym Fitness"
                 class="login-logo" />

            <h2 class="fw-bold mt-4">Crie sua conta</h2>
            <p class="text-muted">Comece sua jornada na Uni Gym Fitness.</p>
        </div>

        <form asp-controller="Account" asp-action="Cadastro" method="post" id="formCadastro">
            <div asp-validation-summary="ModelOnly" class="text-danger mb-3"></div>

            <div class="mb-3">
                <label class="form-label">Nome completo</label>
                <input type="text"
                       name="Nome"
                       value="@Model?.Nome"
                       class="form-control"
                       placeholder="Digite seu nome completo"
                       required>
                <span asp-validation-for="Nome" class="text-danger small"></span>
            </div>

            <div class="mb-3">
                <label class="form-label">E-mail</label>
                <input type="email"
                       name="Email"
                       value="@Model?.Email"
                       class="form-control"
                       placeholder="Digite seu e-mail"
                       required>
                <span asp-validation-for="Email" class="text-danger small"></span>
            </div>

            <div class="mb-3">
                <label class="form-label">Telefone</label>
                <input type="text"
                       name="Telefone"
                       id="telefone"
                       value="@Model?.Telefone"
                       class="form-control"
                       placeholder="(61) 99999-9999"
                       maxlength="15"
                       pattern="\([0-9]{2}\) 9[0-9]{4}-[0-9]{4}"
                       title="Digite um celular válido no formato (61) 99999-9999"
                       required>
                <span asp-validation-for="Telefone" class="text-danger small"></span>
            </div>

            <div class="mb-3">
                <label class="form-label">Plano</label>
                <select name="Plano" class="form-control" required>
                    <option value="">Selecione um plano</option>
                    <option value="Bronze" selected="@(Model?.Plano == "Bronze")">Bronze - R$ 89,90</option>
                    <option value="Silver" selected="@(Model?.Plano == "Silver")">Silver - R$ 129,90</option>
                    <option value="Gold" selected="@(Model?.Plano == "Gold")">Gold - R$ 179,90</option>
                </select>
                <span asp-validation-for="Plano" class="text-danger small"></span>
            </div>

            <div class="mb-3">
                <label class="form-label">Senha</label>
                <input type="password"
                       name="Senha"
                       id="senha"
                       class="form-control"
                       placeholder="Digite sua senha"
                       required>
                <span asp-validation-for="Senha" class="text-danger small"></span>
            </div>

            <div class="mb-3">
                <label class="form-label">Confirmar senha</label>
                <input type="password"
                       name="ConfirmarSenha"
                       id="confirmarSenha"
                       class="form-control"
                       placeholder="Confirme sua senha"
                       required>
            </div>

            <button type="submit" class="btn btn-warning w-100 fw-bold mt-3">
                Criar conta
            </button>

        </form>

        <div class="text-center mt-4">
            <p class="mb-1">Já possui uma conta?</p>
            <a asp-controller="Account"
               asp-action="Login"
               class="text-warning fw-bold text-decoration-none">
                Entrar agora
            </a>
        </div>

    </div>
</section>

@section Scripts {
    <script>
        const telefoneInput = document.getElementById("telefone");
        const formCadastro = document.getElementById("formCadastro");
        const senhaInput = document.getElementById("senha");
        const confirmarSenhaInput = document.getElementById("confirmarSenha");

        telefoneInput.addEventListener("input", function () {
            let valor = telefoneInput.value.replace(/\D/g, "");

            if (valor.length > 11) {
                valor = valor.substring(0, 11);
            }

            if (valor.length > 6) {
                telefoneInput.value = `(${valor.substring(0, 2)}) ${valor.substring(2, 7)}-${valor.substring(7)}`;
            } else if (valor.length > 2) {
                telefoneInput.value = `(${valor.substring(0, 2)}) ${valor.substring(2)}`;
            } else if (valor.length > 0) {
                telefoneInput.value = `(${valor}`;
            }
        });

        formCadastro.addEventListener("submit", function (event) {
            const numerosTelefone = telefoneInput.value.replace(/\D/g, "");

            if (numerosTelefone.length !== 11 || numerosTelefone[2] !== "9") {
                event.preventDefault();
                alert("Digite um celular válido no formato (61) 99999-9999.");
                return;
            }

            if (senhaInput.value !== confirmarSenhaInput.value) {
                event.preventDefault();
                alert("As senhas não conferem.");
                return;
            }
        });
    </script>
}
