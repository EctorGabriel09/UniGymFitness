@model UniGymFitness.Models.Usuario

@{
    ViewData["Title"] = "Editar Usuário";
    Layout = "~/Views/Shared/_DashboardLayout.cshtml";
}

<div class="container">

    <div class="mb-4">
        <h2 class="fw-bold">Editar Usuário</h2>
        <p class="text-muted">Atualize as informações do usuário cadastrado.</p>
    </div>

    <div class="card shadow">
        <div class="card-body">

            <form asp-controller="Usuarios" asp-action="Editar" method="post">

                <input type="hidden" asp-for="Id" />

                <div class="mb-3">
                    <label class="form-label">Nome completo</label>
                    <input asp-for="Nome" class="form-control" />
                </div>

                <div class="mb-3">
                    <label class="form-label">E-mail</label>
                    <input asp-for="Email" class="form-control" />
                </div>

                <div class="mb-3">
                    <label class="form-label">Telefone</label>
                    <input asp-for="Telefone" class="form-control" />
                </div>

                <div class="mb-3">
                    <label class="form-label">Plano</label>
                    <select asp-for="Plano" class="form-control">
                        <option value="Bronze">Bronze - R$ 89,90</option>
                        <option value="Silver">Silver - R$ 129,90</option>
                        <option value="Gold">Gold - R$ 179,90</option>
                    </select>
                </div>

                <div class="mb-3">
                    <label class="form-label">Senha</label>
                    <input asp-for="Senha" class="form-control" type="password" />
                </div>

                <div class="d-flex justify-content-between mt-4">

                    <a asp-controller="Usuarios"
                       asp-action="Index"
                       class="btn btn-secondary">
                        Voltar
                    </a>

                    <button type="submit" class="btn btn-warning fw-bold">
                        Salvar Alterações
                    </button>

                </div>

            </form>

        </div>
    </div>

</div>