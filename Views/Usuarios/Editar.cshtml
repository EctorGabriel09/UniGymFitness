@model UniGymFitness.Models.Usuario

@{
    ViewData["Title"] = "Editar Usuário";
    Layout = "~/Views/Shared/_DashboardLayout.cshtml";
}

<div class="container">

    <div class="mb-4">
        <h2 class="fw-bold">Editar Usuário</h2>
        <p class="text-muted">Atualize as informações do usuário cadastrado.</p>
    </div>

    <div class="card shadow">
        <div class="card-body">

            <form asp-controller="Usuarios" asp-action="Editar" method="post" id="formEditarUsuario">
                <div asp-validation-summary="ModelOnly" class="text-danger mb-3"></div>

                <input type="hidden" asp-for="Id" />
                <input type="hidden" asp-for="Senha" />
                <input type="hidden" asp-for="TipoUsuario" />

                <div class="mb-3">
                    <label class="form-label">Nome completo</label>
                    <input asp-for="Nome" class="form-control" required />
                    <span asp-validation-for="Nome" class="text-danger small"></span>
                </div>

                <div class="mb-3">
                    <label class="form-label">E-mail</label>
                    <input asp-for="Email" class="form-control" type="email" required />
                    <span asp-validation-for="Email" class="text-danger small"></span>
                </div>

                <div class="mb-3">
                    <label class="form-label">Telefone</label>
                    <input asp-for="Telefone"
                           id="telefone"
                           class="form-control"
                           maxlength="15"
                           placeholder="(61) 99999-9999"
                           required />
                    <span asp-validation-for="Telefone" class="text-danger small"></span>
                </div>

                <div class="mb-3">
                    <label class="form-label">Plano</label>
                    <select asp-for="Plano" class="form-control" required>
                        <option value="Bronze">Bronze - R$ 89,90</option>
                        <option value="Silver">Silver - R$ 129,90</option>
                        <option value="Gold">Gold - R$ 179,90</option>
                    </select>
                    <span asp-validation-for="Plano" class="text-danger small"></span>
                </div>

                <div class="d-flex justify-content-between mt-4">

                    <a asp-controller="Usuarios"
                       asp-action="Index"
                       class="btn btn-secondary">
                        Voltar
                    </a>

                    <button type="submit" class="btn btn-warning fw-bold">
                        Salvar Alterações
                    </button>

                </div>

            </form>

        </div>
    </div>

</div>

@section Scripts {
    <script>
        const telefoneInput = document.getElementById("telefone");
        const formEditarUsuario = document.getElementById("formEditarUsuario");

        telefoneInput.addEventListener("input", function () {

            let valor = telefoneInput.value.replace(/\D/g, "");

            if (valor.length > 11)
                valor = valor.substring(0, 11);

            if (valor.length > 6) {
                telefoneInput.value = `(${valor.substring(0,2)}) ${valor.substring(2,7)}-${valor.substring(7)}`;
            }
            else if (valor.length > 2) {
                telefoneInput.value = `(${valor.substring(0,2)}) ${valor.substring(2)}`;
            }
            else if (valor.length > 0) {
                telefoneInput.value = `(${valor}`;
            }

        });

        formEditarUsuario.addEventListener("submit", function (event) {

            const numeros = telefoneInput.value.replace(/\D/g, "");

            if (numeros.length != 11) {
                event.preventDefault();
                alert("Digite um telefone válido.");
            }

        });
    </script>

    <partial name="_ValidationScriptsPartial" />
}
