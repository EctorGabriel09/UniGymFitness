                        Escolher Plano
                    </a>

                </div>

            </div>

        </div>

        <div class="col-md-4 mb-4">

            <div class="card plano-card h-100 shadow">

                <div class="card-body text-center">

                    <h3 class="fw-bold">🥈 Silver</h3>

                    <h2 class="text-warning fw-bold mt-3">
                        R$ 129,90
                    </h2>

                    <hr>

                    <p>✔ Tudo do Bronze</p>

                    <p>✔ Aulas Coletivas</p>

                    <p>✔ Avaliação Física</p>

                    <a href="#" class="btn btn-dark mt-3">
                        Escolher Plano
                    </a>

                </div>

            </div>

        </div>

        <div class="col-md-4 mb-4">

            <div class="card plano-card h-100 shadow">

                <div class="card-body text-center">

                    <h3 class="fw-bold">🥇 Gold</h3>

                    <h2 class="text-warning fw-bold mt-3">
                        R$ 179,90
                    </h2>

                    <hr>

                    <p>✔ Tudo do Silver</p>

                    <p>✔ Personal Trainer</p>

                    <p>✔ Acesso Ilimitado</p>

                    <a href="#" class="btn btn-warning mt-3 fw-bold">
                        Melhor Plano
                    </a>

                </div>

            </div>

        </div>

    </div>

</section>

<section class="contato-section py-5">
    <div class="container">

        <div class="text-center mb-5">
            <h2 class="fw-bold">Entre em Contato</h2>
            <p class="text-muted">
                Estamos prontos para receber você na Uni Gym Fitness.
            </p>
        </div>

        <div class="row g-4 justify-content-center">

            <div class="col-lg-3 col-md-6">
                <div class="contato-card text-center">
                    <div class="contato-icon">📍</div>
                    <h5 class="fw-bold mt-3">Endereço</h5>
                    <p>Shopping Luziânia<br>Centro - Luziânia/GO</p>
                </div>
            </div>

            <div class="col-lg-3 col-md-6">
                <div class="contato-card text-center">
                    <div class="contato-icon">📞</div>
                    <h5 class="fw-bold mt-3">Telefone</h5>
                    <p>(61) 3622-2922</p>
                </div>
            </div>

            <div class="col-lg-3 col-md-6">
                <div class="contato-card text-center">
                    <div class="contato-icon">🕒</div>
                    <h5 class="fw-bold mt-3">Horário</h5>
                    <p>Seg a Sex: 05h às 23h<br>Sáb: 07h às 17h<br>Dom: 08h às 12h</p>
                </div>
            </div>

            <div class="col-lg-3 col-md-6">
