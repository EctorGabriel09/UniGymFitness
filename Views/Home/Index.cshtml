@{
    ViewData["Title"] = "Início";
}

<section class="hero-home">
    <div class="container text-center">
        <h1 class="display-3 fw-bold">UNI GYM FITNESS</h1>

        <p class="lead mt-3">
            Transforme seu corpo. Supere seus limites. Faça parte da Uni Gym Fitness.
        </p>

        <a href="#" class="btn btn-warning btn-lg mt-4 fw-bold">
            Conheça nossos planos
        </a>
    </div>
</section>
<section class="container py-5">

    <div class="row align-items-center">

        <div class="col-md-6">

            <h2 class="fw-bold mb-4">
                Quem Somos
            </h2>

            <p class="fs-5">
                A <strong>Uni Gym Fitness</strong> nasceu com o propósito de transformar vidas através da atividade física.
                Nosso ambiente foi pensado para oferecer conforto, equipamentos modernos e acompanhamento profissional,
                ajudando cada aluno a alcançar seus objetivos com segurança e qualidade.
            </p>

            <p class="fs-5">
                Seja para emagrecer, ganhar massa muscular ou melhorar sua saúde, aqui você encontra a estrutura ideal para evoluir todos os dias.
            </p>

        </div>

        <div class="col-md-6 text-center">

            <img src="https://images.unsplash.com/photo-1689877020200-403d8542d95d?q=80&w=1170&auto=format&fit=crop&ixlib=rb-4.1.0&ixid=M3wxMjA3fDB8MHxwaG90by1wYWdlfHx8fGVufDB8fHx8fA%3D%3D"
                 class="img-fluid rounded shadow"
                 alt="Academia">

        </div>

    </div>

</section>
<section class="container py-5">

    <div class="text-center mb-5">

        <h2 class="fw-bold">
            Nossos Planos
        </h2>

        <p class="text-muted">
            Escolha o plano ideal para alcançar seus objetivos.
        </p>

    </div>

    <div class="row">

        <div class="col-md-4 mb-4">

            <div class="card plano-card h-100 shadow">

                <div class="card-body text-center">

                    <h3 class="fw-bold">🥉 Bronze</h3>

                    <h2 class="text-warning fw-bold mt-3">
                        R$ 89,90
                    </h2>

                    <hr>

                    <p>✔ Musculação</p>

                    <p>✔ Área de Cardio</p>

                    <p>✔ Horário Comercial</p>

                    <a href="#" class="btn btn-dark mt-3">
                        Escolher Plano
                    </a>

                </div>

            </div>

        </div>

        <div class="col-md-4 mb-4">

            <div class="card plano-card h-100 shadow">

                <div class="card-body text-center">

                    <h3 class="fw-bold">🥈 Silver</h3>

                    <h2 class="text-warning fw-bold mt-3">
                        R$ 129,90
                    </h2>

                    <hr>

                    <p>✔ Tudo do Bronze</p>

                    <p>✔ Aulas Coletivas</p>

                    <p>✔ Avaliação Física</p>

                    <a href="#" class="btn btn-dark mt-3">
                        Escolher Plano
                    </a>

                </div>

            </div>

        </div>

        <div class="col-md-4 mb-4">

            <div class="card plano-card h-100 shadow">

                <div class="card-body text-center">

                    <h3 class="fw-bold">🥇 Gold</h3>

                    <h2 class="text-warning fw-bold mt-3">
                        R$ 179,90
                    </h2>

                    <hr>

                    <p>✔ Tudo do Silver</p>

                    <p>✔ Personal Trainer</p>

                    <p>✔ Acesso Ilimitado</p>

                    <a href="#" class="btn btn-warning mt-3 fw-bold">
                        Melhor Plano
                    </a>

                </div>

            </div>

        </div>

    </div>

</section>