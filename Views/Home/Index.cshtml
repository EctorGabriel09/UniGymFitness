@{
    ViewData["Title"] = "Início";
}

<section class="hero-home">
    <div class="container text-center">
        <h1 class="display-3 fw-bold">UNI GYM FITNESS</h1>

        <p class="lead mt-3">
            Transforme seu corpo. Supere seus limites. Faça parte da Uni Gym Fitness.
        </p>

        <a href="#" class="btn btn-warning btn-lg mt-4 fw-bold">
            Conheça nossos planos
        </a>
    </div>
</section>
<section class="container py-5">

    <div class="row align-items-center">

        <div class="col-md-6">

            <h2 class="fw-bold mb-4">
                Quem Somos
            </h2>

            <p class="fs-5">
                A <strong>Uni Gym Fitness</strong> nasceu com o propósito de transformar vidas através da atividade física.
                Nosso ambiente foi pensado para oferecer conforto, equipamentos modernos e acompanhamento profissional,
                ajudando cada aluno a alcançar seus objetivos com segurança e qualidade.
            </p>

            <p class="fs-5">
                Seja para emagrecer, ganhar massa muscular ou melhorar sua saúde, aqui você encontra a estrutura ideal para evoluir todos os dias.
            </p>

        </div>

        <div class="col-md-6 text-center">

            <img src="https://images.unsplash.com/photo-1689877020200-403d8542d95d?q=80&w=1170&auto=format&fit=crop&ixlib=rb-4.1.0&ixid=M3wxMjA3fDB8MHxwaG90by1wYWdlfHx8fGVufDB8fHx8fA%3D%3D"
                 class="img-fluid rounded shadow"
                 alt="Academia">

        </div>

    </div>
<section class="diferenciais-section py-5">

    <div class="container">

        <div class="text-center mb-5">
            <h2 class="fw-bold">Nossos Diferenciais</h2>
            <p class="text-muted">
                Estrutura completa para você treinar com qualidade, segurança e motivação.
            </p>
        </div>

        <div class="row g-4">

            <div class="col-lg-3 col-md-6">
                <div class="card diferencial-card h-100 text-center shadow">
                    <div class="card-body">
                        <div class="diferencial-icon">🏋️</div>
                        <h5 class="fw-bold mt-3">Equipamentos Modernos</h5>
                        <p>
                            Equipamentos modernos e de alta qualidade para proporcionar mais conforto, segurança e eficiência em cada treino.
                        </p>
                    </div>
                </div>
            </div>

            <div class="col-lg-3 col-md-6">
                <div class="card diferencial-card h-100 text-center shadow">
                    <div class="card-body">
                        <div class="diferencial-icon">🙎​</div>
                        <h5 class="fw-bold mt-3">Personal Trainer</h5>
                        <p>
                            Profissionais qualificados para orientar seus treinos e ajudar você a alcançar seus objetivos.
                        </p>
                    </div>
                </div>
            </div>

            <div class="col-lg-3 col-md-6">
                <div class="card diferencial-card h-100 text-center shadow">
                    <div class="card-body">
                        <div class="diferencial-icon">📈</div>
                        <h5 class="fw-bold mt-3">Avaliação Física</h5>
                        <p>
                            Acompanhamento completo para medir sua evolução e criar um plano personalizado.
                        </p>
                    </div>
                </div>
            </div>

            <div class="col-lg-3 col-md-6">
                <div class="card diferencial-card h-100 text-center shadow">
                    <div class="card-body">
                        <div class="diferencial-icon">🕒</div>
                        <h5 class="fw-bold mt-3">Horários Flexíveis</h5>
                        <p>
                            Funcionamento em horários amplos para que você treine quando for mais conveniente.
                        </p>
                    </div>
                </div>
            </div>

        </div>

    </div>

</section>

</section>
